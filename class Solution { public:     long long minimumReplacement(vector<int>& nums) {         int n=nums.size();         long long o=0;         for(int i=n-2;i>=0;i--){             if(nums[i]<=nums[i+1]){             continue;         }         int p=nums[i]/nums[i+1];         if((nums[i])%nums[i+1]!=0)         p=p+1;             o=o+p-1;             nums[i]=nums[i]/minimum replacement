class Solution {
public:
    long long minimumReplacement(vector<int>& nums) {
        int n=nums.size();
        long long o=0;
        for(int i=n-2;i>=0;i--){
            if(nums[i]<=nums[i+1]){
            continue;
        }
        int p=nums[i]/nums[i+1];
        if((nums[i])%nums[i+1]!=0)
        p=p+1;
            o=o+p-1;
            nums[i]=nums[i]/p;

        }
        return o;
    }
};
